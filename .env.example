# ============================================================
# CEVECOM-MARTA-V2 — Configuración de entorno
# ============================================================
# Copia este archivo como .env y rellena cada valor.
# NUNCA subas el archivo .env a git.
# El sistema valida todas las variables al arrancar y da
# un error claro si falta alguna.
# ============================================================


# ============================================================
# MÓDULO 1 — Generación automática de Reels de Instagram
# ============================================================


# ------------------------------------------------------------
# ANTHROPIC — Claude API (generación de guiones)
# ------------------------------------------------------------
# Dónde conseguirla:
#   1. Ve a https://console.anthropic.com
#   2. Sección "API Keys" → "Create Key"
#   3. Copia la clave completa (empieza por sk-ant-...)
ANTHROPIC_API_KEY=


# ------------------------------------------------------------
# HEYGEN — Generación de vídeo con avatar
# ------------------------------------------------------------
# Dónde conseguirla:
#   1. Ve a https://app.heygen.com
#   2. Menú superior derecho → Settings → API
#   3. "Generate API Token" → copia el token
HEYGEN_API_KEY=


# ------------------------------------------------------------
# GOOGLE SHEETS — Hoja de briefings de Marta
# ------------------------------------------------------------
# ID de la hoja de cálculo.
# Dónde conseguirlo:
#   Abre la hoja en el navegador. La URL tiene este formato:
#   https://docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
#   Copia solo la parte entre /d/ y /edit
GOOGLE_SHEETS_ID=

# Ruta al archivo credentials.json de la cuenta de servicio de Google.
# Dónde conseguirlo:
#   1. Ve a https://console.cloud.google.com
#   2. Crea un proyecto nuevo (o usa uno existente)
#   3. Activa estas dos APIs: "Google Sheets API" y "Google Drive API"
#   4. Ve a "APIs & Services" → "Credentials"
#   5. Crea una "Service Account" → descarga el JSON
#   6. Guarda el JSON como credentials.json en la raíz del proyecto
#   7. En Google Sheets: comparte la hoja con el email de la service account
#      (aparece en el JSON como "client_email")
GOOGLE_CREDENTIALS_PATH=credentials.json


# ------------------------------------------------------------
# EMAIL — Notificaciones y flujo de aprobación de contenido
# ------------------------------------------------------------
# Cuenta de Gmail desde la que el sistema envía los correos a Marta.
# No cambies SMTP_HOST ni SMTP_PORT salvo que uses otro proveedor.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=

# Contraseña de aplicación de Gmail.
# IMPORTANTE: NO uses tu contraseña normal de Gmail. Necesitas una
# "Contraseña de aplicación" específica para esto.
# Dónde conseguirla:
#   1. Ve a https://myaccount.google.com
#   2. Seguridad → Verificación en 2 pasos (debe estar activada)
#   3. Abajo del todo: "Contraseñas de aplicaciones"
#   4. Selecciona "Correo" + dispositivo "Windows" → Generar
#   5. Copia las 16 letras que aparecen (sin espacios)
EMAIL_SMTP_PASSWORD=

# Correo electrónico de Marta. Recibirá los vídeos para revisión
# con los botones Aprobar / Rechazar.
EMAIL_DESTINATARIO=

# Correo de Cedric (prestador del servicio). Recibe copia de TODO:
# confirmaciones de publicación, rechazos de Marta, y errores técnicos
# que Marta no llega a ver (fallos de HeyGen, errores de Instagram, etc.).
# Durante pruebas: pon el email de Cedric en AMBAS variables para que
# todas las notificaciones lleguen al mismo sitio sin molestar a Marta.
EMAIL_COPIA_PRESTADOR=


# ------------------------------------------------------------
# GOOGLE APPS SCRIPT — Webhook de aprobación por email
# ------------------------------------------------------------
# URL del script de Google que procesa los clics en Aprobar / Rechazar.
# Dónde conseguirla (hazlo después de crear el Apps Script):
#   1. Ve a https://script.google.com
#   2. Abre el proyecto webhook_aprobacion
#   3. Implementar → Nueva implementación → Tipo: Aplicación web
#   4. Ejecutar como: Yo (tu cuenta)
#   5. Quién tiene acceso: Cualquier usuario
#   6. Implementar → copia la URL que aparece
APPS_SCRIPT_WEBHOOK_URL=


# ------------------------------------------------------------
# META / INSTAGRAM — Publicación automática de Reels
# ------------------------------------------------------------
# App ID y App Secret de tu Facebook App.
# Dónde conseguirlos:
#   1. Ve a https://developers.facebook.com/apps
#   2. "Crear app" → Tipo: Empresa (Business)
#   3. Una vez creada: Configuración → Básica
#   4. Copia "ID de la aplicación" y "Clave secreta de la app"
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ID de la Página de Facebook conectada a la cuenta de Instagram de Marta.
# Dónde conseguirlo:
#   1. Ve a https://www.facebook.com/[nombre-de-la-pagina]/about
#   2. Busca "ID de la página" al final de la sección Información general
#   O desde Graph API Explorer: GET /me/accounts → campo "id"
FACEBOOK_PAGE_ID=

# ID de la cuenta de Instagram Business de Marta.
# Dónde conseguirlo (después de obtener el FACEBOOK_ACCESS_TOKEN):
#   Graph API Explorer → GET /{FACEBOOK_PAGE_ID}?fields=instagram_business_account
#   El resultado tiene la forma: { "instagram_business_account": { "id": "XXXX" } }
INSTAGRAM_USER_ID=

# Token de acceso de larga duración (válido 60 días).
# El sistema lo renueva automáticamente antes de que expire.
# Cómo generarlo por primera vez:
#   1. Ve a https://developers.facebook.com/tools/explorer
#   2. Selecciona tu App en el desplegable superior
#   3. Haz clic en "Generar token de acceso"
#   4. Marca estos permisos:
#        - instagram_content_publish
#        - instagram_basic
#        - pages_show_list
#        - pages_read_engagement
#        - pages_manage_posts
#   5. Copia el token (es de corta duración, ~1 hora)
#   6. Ejecuta: python tools/renovar_token_meta.py
#      El script lo convierte a token de 60 días y actualiza este archivo
FACEBOOK_ACCESS_TOKEN=

# Fecha de expiración del token (formato YYYY-MM-DD).
# El sistema avisa por log cuando faltan menos de 10 días para renovar.
# Se actualiza automáticamente cada vez que se renueva el token.
FACEBOOK_ACCESS_TOKEN_EXPIRY=


# ============================================================
# MÓDULO 2 — Agente de respuesta automática a DMs de Instagram
# ============================================================


# ------------------------------------------------------------
# OPENAI — Agente de DMs con vector store de conocimiento
# ------------------------------------------------------------
# Clave de API de OpenAI. Solo la usa el Módulo 2 (DMs).
# Dónde conseguirla:
#   1. Ve a https://platform.openai.com/api-keys
#   2. "Create new secret key" → copia la clave (empieza por sk-...)
OPENAI_API_KEY=

# ID del vector store con toda la información del centro:
# precios, tratamientos, FAQ, horarios, política de cancelación...
# Ya creado — no modificar salvo que migres a un nuevo vector store.
OPENAI_VECTOR_STORE_ID=vs_69ea49679ce481918f6290836692c47f

# ID del Assistant de OpenAI configurado para responder DMs.
# Ya creado y configurado con las instrucciones del agente.
# No modificar salvo que crees un nuevo assistant desde cero.
OPENAI_ASSISTANT_ID=asst_tL5WYNDN1dEk2qb08pTlqyqx

# Token secreto para verificar el webhook de Meta (DMs de Instagram).
# Elige cualquier string aleatorio — debe coincidir exactamente con el valor
# que configures en Facebook App → Productos → Webhooks → Verificar y guardar.
META_WEBHOOK_VERIFY_TOKEN=


# ============================================================
# DESPLIEGUE RAILWAY — sólo para entornos desplegados
# ============================================================


# ------------------------------------------------------------
# DATABASE_URL — PostgreSQL de Railway (contexto de DMs)
# ------------------------------------------------------------
# Reemplaza la BD SQLite local (dm_context.db) por PostgreSQL nativo de
# Railway, que persiste entre reinicios del contenedor.
#
# Inyección automática en Railway:
#   Si tienes el servicio web y un servicio "Postgres" en el MISMO proyecto
#   de Railway, DATABASE_URL aparece sola en las variables del web service.
#   No la pongas a mano allí.
#
# Para uso LOCAL (probar antes de desplegar, o ejecutar
# tools/migrar_sqlite_a_postgres.py):
#   1. En el dashboard de Railway abre el servicio Postgres
#   2. Pestaña "Connect" → sección "Public Network"
#   3. Copia DATABASE_PUBLIC_URL completo aquí abajo
DATABASE_URL=


# ------------------------------------------------------------
# GOOGLE_CREDENTIALS_JSON — Service Account como variable
# ------------------------------------------------------------
# En Railway no se sube credentials.json al repo (.gitignore lo excluye).
# En su lugar, pega el contenido completo del JSON aquí (una sola línea).
# Si está definida, los tools usan el contenido directamente. Si no, hacen
# fallback a GOOGLE_CREDENTIALS_PATH como en local.
#
# Cómo prepararla:
#   1. Abre tu credentials.json
#   2. Copia el contenido completo (todo el objeto JSON, una línea)
#   3. Pégalo en Railway → web service → Variables → New Variable
#      Nombre: GOOGLE_CREDENTIALS_JSON  Valor: { "type": "service_account", ... }
#   4. En LOCAL no hace falta — basta con tener credentials.json y
#      GOOGLE_CREDENTIALS_PATH apuntando al archivo.
GOOGLE_CREDENTIALS_JSON=
